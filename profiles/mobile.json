{
  "name": "mobile-readable",
  "description": "Large font, wide line height, A5 page size for mobile/phone reading, 150 DPI for smaller files",
  "page": {
    "width": 420,
    "height": 595
  },
  "margins": {
    "top": 50,
    "bottom": 60,
    "left": 40,
    "right": 40
  },
  "body_text": {
    "font_size": 14,
    "line_height": 1.8,
    "color": [0, 0, 0]
  },
  "heading_scale": {
    "h1": 1.8,
    "h2": 1.4,
    "h3": 1.2
  },
  "dpi": 150,
  "jpeg_quality": 80,
  "watermark": {
    "font_size": 12,
    "opacity": 0.25,
    "angle": 45,
    "color": [0.75, 0.75, 0.75],
    "spacing": 150
  },
  "footer": {
    "enabled": true,
    "font_size": 7,
    "opacity": 0.6,
    "color": [0.4, 0.4, 0.4]
  }
}
