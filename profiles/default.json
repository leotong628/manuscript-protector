    "font_size": 20,
    "opacity": 0.25,
    "angle": 45,
    "color": [0.75, 0.75, 0.75],
    "spacing": 200
  },
  "footer": {
    "enabled": true,
    "font_size": 8,
    "opacity": 0.6,
    "color": [0.4, 0.4, 0.4]
